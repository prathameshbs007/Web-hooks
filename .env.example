DATABASE_URL=postgresql+asyncpg://relay:relay@postgres:5432/relay
REDIS_URL=redis://redis:6379/0
ADMIN_TOKEN=change-me
# Diagnosis agent LLM. Default is Google Gemini — the free key comes from
# https://aistudio.google.com (no credit card). Set LLM_PROVIDER=anthropic
# with a claude-* model to use Anthropic instead (needs langchain-anthropic).
LLM_PROVIDER=gemini
# gemini-3.1-flash-lite works on new free keys and is light enough for a
# multi-call diagnosis. (gemini-2.5-flash 404s for newly created keys.)
LLM_MODEL=gemini-3.1-flash-lite
LLM_API_KEY=
AGENT_MAX_RUNS_PER_ENDPOINT_PER_HOUR=1
AGENT_MAX_RUNS_PER_DAY=10
WORKER_CONCURRENCY=32
STREAM_SHARDS=8
DEFAULT_TENANT_RATE_PER_SEC=50
DEFAULT_TENANT_MAX_INFLIGHT=20
DELIVERY_TIMEOUT_SECONDS=10
MAX_ATTEMPTS=7
