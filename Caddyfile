# Caddy reverse proxy with automatic HTTPS (Let's Encrypt).
# Only the dashboard/API is public. Set RELAY_DOMAIN in .env; Caddy provisions
# and renews the certificate once the domain's DNS A record points at this host.
#
# Grafana is intentionally NOT exposed here — it's an internal ops tool, reached
# over an SSH tunnel (see the deploy docs), not a public URL.

{$RELAY_DOMAIN} {
	encode gzip
	reverse_proxy api:8000
}
