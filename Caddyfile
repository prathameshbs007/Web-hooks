# Caddy reverse proxy with automatic HTTPS (Let's Encrypt).
# Set RELAY_DOMAIN and GRAFANA_DOMAIN in .env; Caddy provisions and renews
# certificates on its own once the domains' DNS A records point at this host.

{$RELAY_DOMAIN} {
	encode gzip
	reverse_proxy api:8000
}

{$GRAFANA_DOMAIN} {
	encode gzip
	reverse_proxy grafana:3000
}
